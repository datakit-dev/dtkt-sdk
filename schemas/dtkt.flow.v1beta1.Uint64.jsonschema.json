{
  "$id": "dtkt.flow.v1beta1.Uint64.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "default": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "pattern": "^[0-9]+$",
          "type": "string"
        }
      ]
    },
    "nullable": {
      "default": false,
      "type": "boolean"
    }
  },
  "title": "Uint64",
  "type": "object"
}
