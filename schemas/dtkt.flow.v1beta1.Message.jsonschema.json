{
  "$id": "dtkt.flow.v1beta1.Message.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Proto message type",
  "properties": {
    "default": {
      "$ref": "google.protobuf.Struct.jsonschema.json"
    },
    "nullable": {
      "default": false,
      "type": "boolean"
    },
    "type": {
      "description": "Fully qualified message name: \"google.protobuf.Struct\", \"google.protobuf.Timestamp\", etc.",
      "minLength": 1,
      "pattern": "^[a-zA-Z][a-zA-Z0-9_.]+$",
      "type": "string"
    }
  },
  "required": [
    "type"
  ],
  "title": "Message",
  "type": "object"
}
