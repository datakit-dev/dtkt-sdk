{
  "$id": "dtkt.core.v1.UpdateFlowRequest.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "patternProperties": {
    "^(update_mask)$": {
      "$ref": "google.protobuf.FieldMask.jsonschema.json",
      "description": "Fields to update (e.g., \"spec\")."
    }
  },
  "properties": {
    "flow": {
      "$ref": "dtkt.core.v1.Flow.jsonschema.json",
