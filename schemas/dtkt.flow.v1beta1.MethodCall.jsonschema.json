{
  "$id": "dtkt.flow.v1beta1.MethodCall.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "connection": {
      "minLength": 1,
      "pattern": "^[a-zA-Z][a-zA-Z0-9_]+$",
      "type": "string"
    },
    "method": {
      "minLength": 1,
      "pattern": "[a-zA-Z._/]+",
      "type": "string"
    },
    "request": {
      "$ref": "google.protobuf.Value.jsonschema.json"
    },
    "response": {
      "default": "",
      "pattern": "^\\s?=\\s?",
      "type": "string"
    }
  },
  "required": [
    "connection",
    "method"
  ],
  "title": "Method Call",
  "type": "object"
}
