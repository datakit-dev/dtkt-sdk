{
  "$id": "dtkt.replication.v1beta1.CheckSourceAuthRequest.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Request for checking source auth.",
  "patternProperties": {
    "^(code_request)$": {
      "$ref": "dtkt.shared.v1beta1.OAuthCodeRequest.jsonschema.json",
      "description": "When check type is auth code url."
    },
    "^(config_id)$": {
      "default": "",
      "description": "Unique identifier of source config from replication service.",
      "type": "string"
    },
    "^(refresh_request)$": {
      "$ref": "dtkt.shared.v1beta1.OAuthRefreshRequest.jsonschema.json",
      "description": "When check type is refresh."
    },
    "^(token_request)$": {
      "$ref": "dtkt.shared.v1beta1.OAuthTokenRequest.jsonschema.json",
      "description": "When check type is callback."
    }
  },
  "properties": {
    "codeRequest": {
      "$ref": "dtkt.shared.v1beta1.OAuthCodeRequest.jsonschema.json",
      "description": "When check type is auth code url."
    },
    "configId": {
      "default": "",
      "description": "Unique identifier of source config from replication service.",
      "type": "string"
    },
    "refreshRequest": {
      "$ref": "dtkt.shared.v1beta1.OAuthRefreshRequest.jsonschema.json",
      "description": "When check type is refresh."
    },
    "service": {
      "anyOf": [
        {
          "pattern": "^SERVICE_TYPE_UNSPECIFIED$",
          "type": "string"
        },
        {
          "enum": [
            "SERVICE_TYPE_FIVETRAN"
          ],
          "type": "string"
        },
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      ],
      "default": 0,
      "description": "Replication service the Source.",
      "title": "Service Type"
    },
    "tokenRequest": {
      "$ref": "dtkt.shared.v1beta1.OAuthTokenRequest.jsonschema.json",
      "description": "When check type is callback."
    },
    "type": {
      "anyOf": [
        {
          "pattern": "^AUTH_CHECK_UNSPECIFIED$",
          "type": "string"
        },
        {
          "enum": [
            "AUTH_CHECK_OAUTH_CODE",
            "AUTH_CHECK_OAUTH_CALLBACK",
            "AUTH_CHECK_OAUTH_REFRESH"
          ],
          "type": "string"
        },
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      ],
      "default": 0,
      "description": "The auth check type.",
      "title": "Auth Check"
    }
  },
  "title": "Check Source Auth Request",
  "type": "object"
}
