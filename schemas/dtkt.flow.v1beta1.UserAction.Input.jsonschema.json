{
  "$id": "dtkt.flow.v1beta1.UserAction.Input.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "patternProperties": {
    "^(multi_select)$": {
      "$ref": "dtkt.protoform.v1beta1.MultiSelectElement.jsonschema.json"
    }
  },
  "properties": {
    "confirm": {
      "$ref": "dtkt.protoform.v1beta1.ConfirmElement.jsonschema.json"
    },
    "description": {
      "pattern": "^\\s?(=)?\\s?(.*)$",
      "type": "string"
    },
    "file": {
      "$ref": "dtkt.protoform.v1beta1.FileElement.jsonschema.json"
    },
    "id": {
      "minLength": 1,
      "pattern": "^[a-zA-Z][a-zA-Z0-9_]+$",
      "type": "string"
    },
    "input": {
      "$ref": "dtkt.protoform.v1beta1.InputElement.jsonschema.json"
    },
    "multiSelect": {
      "$ref": "dtkt.protoform.v1beta1.MultiSelectElement.jsonschema.json"
    },
    "select": {
      "$ref": "dtkt.protoform.v1beta1.SelectElement.jsonschema.json"
    },
    "title": {
      "minLength": 1,
      "pattern": "^\\s?(=)?\\s?(.*)$",
      "type": "string"
    }
  },
  "required": [
    "id",
    "title"
  ],
  "title": "Input",
  "type": "object"
}
