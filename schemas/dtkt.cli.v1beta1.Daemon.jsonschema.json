{
  "$id": "dtkt.cli.v1beta1.Daemon.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Local daemon configuration",
  "patternProperties": {
    "^(log_file_path)$": {
      "default": "",
      "description": "Log file path",
      "minLength": 1,
      "type": "string"
    },
    "^(pid_file_path)$": {
      "default": "",
      "description": "Process ID file path",
      "minLength": 1,
      "type": "string"
    },
    "^(socket_path)$": {
      "description": "Socket file path",
      "type": "string"
    },
    "^(tcp_address)$": {
      "description": "Daemon TCP address",
      "minLength": 1,
      "pattern": "^([A-Za-z0-9][A-Za-z0-9-]{0,63}(\\.[A-Za-z0-9-][A-Za-z0-9-]{0,63})*|((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)|\\[(([0-9a-fA-F]{1,4}::?){1,7}([0-9a-fA-F]{1,4})|([0-9a-fA-F]{1,4}:){1,7}:|:((([0-9a-fA-F]{1,4}:){1,6})?[0-9a-fA-F]{1,4})?|::)\\]):([1-9][0-9]{0,4}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$",
      "type": "string"
    }
  },
  "properties": {
    "logFilePath": {
      "default": "",
      "description": "Log file path",
      "minLength": 1,
      "type": "string"
    },
    "pidFilePath": {
      "default": "",
      "description": "Process ID file path",
      "minLength": 1,
      "type": "string"
    },
    "socketPath": {
      "description": "Socket file path",
      "type": "string"
    },
    "tcpAddress": {
      "description": "Daemon TCP address",
      "minLength": 1,
      "pattern": "^([A-Za-z0-9][A-Za-z0-9-]{0,63}(\\.[A-Za-z0-9-][A-Za-z0-9-]{0,63})*|((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)|\\[(([0-9a-fA-F]{1,4}::?){1,7}([0-9a-fA-F]{1,4})|([0-9a-fA-F]{1,4}:){1,7}:|:((([0-9a-fA-F]{1,4}:){1,6})?[0-9a-fA-F]{1,4})?|::)\\]):([1-9][0-9]{0,4}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$",
      "type": "string"
    }
  },
  "required": [
    "tcpAddress",
    "socketPath"
  ],
  "title": "Daemon",
  "type": "object"
}
