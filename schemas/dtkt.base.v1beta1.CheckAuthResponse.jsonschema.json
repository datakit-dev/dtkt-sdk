{
  "$id": "dtkt.base.v1beta1.CheckAuthResponse.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Response for checking auth.",
  "patternProperties": {
    "^(auth_code_url)$": {
      "description": "Returned when check is code.",
      "type": "string"
    }
  },
  "properties": {
    "authCodeUrl": {
      "description": "Returned when check is code.",
      "type": "string"
    },
    "error": {
      "default": "",
      "description": "Error message if success is false.",
      "type": "string"
    },
    "success": {
      "default": false,
      "description": "Indicates if the auth check was successful.",
      "type": "boolean"
    },
    "token": {
      "$ref": "dtkt.shared.v1beta1.OAuthToken.jsonschema.json",
      "description": "Returned when check type is token or refresh."
    },
    "type": {
      "anyOf": [
        {
          "pattern": "^AUTH_TYPE_UNSPECIFIED$",
          "type": "string"
        },
        {
          "enum": [
            "AUTH_TYPE_OAUTH"
          ],
          "type": "string"
        },
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      ],
      "default": 0,
      "description": "The auth type.",
      "title": "Auth Type"
    }
  },
  "title": "Check Auth Response",
  "type": "object"
}
