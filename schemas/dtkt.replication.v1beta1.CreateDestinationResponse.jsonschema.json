  "description": "Response from create configured destination.",
  "properties": {
    "created": {
      "default": false,
      "description": "Indicates whether destination was successfully created.",
      "type": "boolean"
    },
    "destination": {
      "$ref": "dtkt.replication.v1beta1.Destination.jsonschema.json",
