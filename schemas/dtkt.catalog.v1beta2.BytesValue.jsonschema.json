{
  "$id": "dtkt.catalog.v1beta2.BytesValue.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Nullable wrapper message for `bytes`.",
