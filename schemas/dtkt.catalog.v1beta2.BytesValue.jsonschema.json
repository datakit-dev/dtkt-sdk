      "type": "boolean"
    },
    "value": {
      "default": null,
      "description": "The bytes value.",
      "pattern": "^[A-Za-z0-9+/]*={0,2}$",
      "type": "string"
    }
  },
  "title": "Bytes Value",
  "type": "object"
}
