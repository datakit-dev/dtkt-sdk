{
  "$id": "cel.expr.Value.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "This is similar to `google.protobuf.Value`, but can represent CEL's full\n range of values.",
  "patternProperties": {
    "^(bool_value)$": {
      "description": "Boolean value.",
      "type": "boolean"
    },
    "^(bytes_value)$": {
      "description": "Byte string value.",
      "pattern": "^[A-Za-z0-9+/]*={0,2}$",
      "type": "string"
    },
    "^(double_value)$": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "enum": [
            "Infinity",
            "-Infinity",
            "NaN"
          ],
          "type": "string"
        },
        {
          "type": "string"
        }
      ],
      "description": "Floating point value."
    },
    "^(enum_value)$": {
      "$ref": "cel.expr.EnumValue.jsonschema.json",
      "description": "An enum value."
    },
    "^(int64_value)$": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "description": "Signed integer value."
    },
    "^(list_value)$": {
      "$ref": "cel.expr.ListValue.jsonschema.json",
      "description": "List value."
    },
    "^(map_value)$": {
      "$ref": "cel.expr.MapValue.jsonschema.json",
      "description": "Map value."
    },
    "^(null_value)$": {
      "anyOf": [
        {
          "enum": [
            "NULL_VALUE"
          ],
          "type": "string"
        },
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      ],
      "description": "Null value.",
      "title": "Null Value"
    },
    "^(object_value)$": {
      "$ref": "google.protobuf.Any.jsonschema.json",
      "description": "The proto message backing an object value."
    },
    "^(string_value)$": {
      "description": "UTF-8 string value.",
      "type": "string"
    },
    "^(type_value)$": {
      "description": "Type value.",
      "type": "string"
    },
    "^(uint64_value)$": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "pattern": "^[0-9]+$",
          "type": "string"
        }
      ],
      "description": "Unsigned integer value."
    }
  },
  "properties": {
    "boolValue": {
      "description": "Boolean value.",
      "type": "boolean"
    },
    "bytesValue": {
      "description": "Byte string value.",
      "pattern": "^[A-Za-z0-9+/]*={0,2}$",
      "type": "string"
    },
    "doubleValue": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "enum": [
            "Infinity",
            "-Infinity",
            "NaN"
          ],
          "type": "string"
        },
        {
          "type": "string"
        }
      ],
      "description": "Floating point value."
    },
    "enumValue": {
      "$ref": "cel.expr.EnumValue.jsonschema.json",
      "description": "An enum value."
    },
    "int64Value": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "description": "Signed integer value."
    },
    "listValue": {
      "$ref": "cel.expr.ListValue.jsonschema.json",
      "description": "List value."
    },
    "mapValue": {
      "$ref": "cel.expr.MapValue.jsonschema.json",
      "description": "Map value."
    },
    "nullValue": {
      "anyOf": [
        {
          "enum": [
            "NULL_VALUE"
          ],
          "type": "string"
        },
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      ],
      "description": "Null value.",
      "title": "Null Value"
    },
    "objectValue": {
      "$ref": "google.protobuf.Any.jsonschema.json",
      "description": "The proto message backing an object value."
    },
    "stringValue": {
      "description": "UTF-8 string value.",
      "type": "string"
    },
    "typeValue": {
      "description": "Type value.",
      "type": "string"
    },
    "uint64Value": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "pattern": "^[0-9]+$",
          "type": "string"
        }
      ],
      "description": "Unsigned integer value."
    }
  },
  "title": "Represents a CEL value.",
  "type": "object"
}
