{
  "$id": "dtkt.geojson.v1beta1.Position.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Represents a GeoJSON Position (array of numbers: length 2 or 3)",
  "properties": {
    "values": {
      "items": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "enum": [
              "Infinity",
              "-Infinity",
              "NaN"
            ],
            "type": "string"
          },
          {
            "type": "string"
          }
        ]
      },
      "type": "array"
    }
  },
  "title": "Position",
  "type": "object"
}
