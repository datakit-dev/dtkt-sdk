{
  "$id": "dtkt.flow.v1beta1.Output.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "id": {
      "minLength": 1,
      "pattern": "^[a-zA-Z][a-zA-Z0-9_]+$",
      "type": "string"
    },
    "value": {
      "minLength": 1,
      "pattern": "^\\s?=\\s?",
      "type": "string"
    }
  },
  "required": [
    "id",
    "value"
  ],
  "title": "Output",
  "type": "object"
}
