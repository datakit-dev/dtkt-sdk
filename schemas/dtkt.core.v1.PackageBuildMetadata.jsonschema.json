{
  "$id": "dtkt.core.v1.PackageBuildMetadata.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "PackageBuildMetadata contains build metadata for a software package, which\n may be used to build a deployment artifact for a compatible runtime environment.",
  "patternProperties": {
    "^(artifact_etag)$": {
      "description": "Checksum of build artifact (present if build is successful).",
      "type": "string"
    },
    "^(artifact_uri)$": {
      "description": "URI of build artifact. (e.g. file://path/to/artifact or docker://image:tag)",
      "minLength": 1,
      "pattern": "^(?:(?:[a-zA-Z][a-zA-Z\\d+\\-.]*):)?(?://(?:[A-Za-z0-9\\-\\.]+(?::\\d+)?))?(/[^\\?#]*)?(?:\\?([^\\#]*))?(?:\\#(.*))?$",
      "type": "string"
    }
  },
  "properties": {
    "artifactEtag": {
      "description": "Checksum of build artifact (present if build is successful).",
      "type": "string"
    },
    "artifactUri": {
      "description": "URI of build artifact. (e.g. file://path/to/artifact or docker://image:tag)",
      "minLength": 1,
      "pattern": "^(?:(?:[a-zA-Z][a-zA-Z\\d+\\-.]*):)?(?://(?:[A-Za-z0-9\\-\\.]+(?::\\d+)?))?(/[^\\?#]*)?(?:\\?([^\\#]*))?(?:\\#(.*))?$",
      "type": "string"
    },
    "env": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Build environment variables.",
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "platform": {
      "$ref": "dtkt.core.v1.PackageBuildMetadata.Platform.jsonschema.json",
      "description": "Target platform of build artifact."
    },
    "runtime": {
      "$ref": "dtkt.core.v1.PackageBuildMetadata.Runtime.jsonschema.json",
      "description": "Target runtime of build artifact."
    }
  },
  "required": [
    "runtime",
    "platform",
    "artifactUri",
    "artifactEtag"
  ],
  "title": "Package Build Metadata",
  "type": "object"
}
